rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // fitlog is solo-only. The entire data model lives under
    // users/{uid}/... and only the owner reads or writes it.
    // No social paths means no cross-user access helpers are needed.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
